{
  "name": "@rimori/playwright-testing",
  "version": "0.3.25",
  "description": "Playwright testing utilities for Rimori plugins and workers",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rimori-org/playwright-testing.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:harness",
    "build:harness": "vite build --config harness.vite.config.ts",
    "dev": "tsc -w --preserveWatchOutput -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:headed:debug": "playwright test --headed --debug"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "peerDependencies": {
    "@playwright/test": "^1.40.0",
    "@rimori/client": "^2.5.36"
  },
  "devDependencies": {
    "@module-federation/enhanced": "2.3.3",
    "@module-federation/vite": "1.15.0",
    "@playwright/test": "^1.40.0",
    "@rimori/client": "^2.5.36",
    "@rimori/react-client": "^0.4.19",
    "@tanstack/react-query": "^5.56.2",
    "@types/node": "^20.12.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.7.2",
    "vite": "^5.4.18",
    "zod": "^3.23.8"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  }
}
