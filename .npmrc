# Note: `minimum-release-age` and `minimum-release-age-exclude` are configured in
# pnpm-workspace.yaml — pnpm 11's lockfile policy check does NOT read them from .npmrc.

# Install scripts gated to a known allowlist
only-built-dependencies[]=esbuild
only-built-dependencies[]=@swc/core
only-built-dependencies[]=@parcel/watcher
only-built-dependencies[]=puppeteer
only-built-dependencies[]=playwright-core
only-built-dependencies[]=sharp

# Compat hoisting for module federation + tooling that expects flat layout
public-hoist-pattern[]=@types/*
public-hoist-pattern[]=eslint*
public-hoist-pattern[]=prettier
public-hoist-pattern[]=@module-federation/*
public-hoist-pattern[]=@vitejs/*

# Resolution
resolution-mode=highest
strict-peer-dependencies=false
auto-install-peers=true
